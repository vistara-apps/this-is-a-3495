# Archilyzer Environment Variables

# OpenRouter API for AI-enhanced layout generation
VITE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Google Maps API for location services
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Application Environment
VITE_APP_ENV=development

# API Base URL (for production)
VITE_API_BASE_URL=https://api.archilyzer.com/v1

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=your-sentry-dsn-here

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=your-ga-id-here

# Feature Flags
VITE_ENABLE_AI_GENERATION=true
VITE_ENABLE_LOCATION_SERVICES=true
VITE_ENABLE_EXPORT_FEATURES=true

# Development Settings
VITE_DEBUG_MODE=false
VITE_MOCK_API_RESPONSES=false
